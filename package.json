{
  "name": "javascript-security-scanner",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "scan": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/scan_entry.ps1 -TargetKey repo",
